# ─── Environment ─────────────────────────────────────────────────────────────
FLASK_ENV=production

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_secret_key_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Email (Gmail example) ────────────────────────────────────────────────────
# Use an App Password if 2FA is enabled: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=WealthSync <your_email@gmail.com>

# ─── URL Scheme ───────────────────────────────────────────────────────────────
# Set to 'https' in production (Render automatically handles this)
PREFERRED_URL_SCHEME=https

# ─── Database ─────────────────────────────────────────────────────────────────
# For SQLite: sqlite:///wealthsync.db (relative to instance/)
# For PostgreSQL: postgresql://user:password@host:5432/wealthsync
# DATABASE_URL=postgresql://user:password@host:5432/wealthsync
